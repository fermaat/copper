{
  "info": {
    "_postman_id": "copper-api-collection",
    "name": "Copper API",
    "description": "Mentecobres — AI-maintained knowledge bases. Set the base_url variable to http://localhost:8000.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000",
      "type": "string"
    },
    {
      "key": "mind",
      "value": "my-mind",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Minds",
      "item": [
        {
          "name": "List all minds",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/minds",
              "host": ["{{base_url}}"],
              "path": ["minds"]
            }
          },
          "response": []
        },
        {
          "name": "Forge a mind",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{mind}}\",\n  \"topic\": \"artificial intelligence and machine learning\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/minds",
              "host": ["{{base_url}}"],
              "path": ["minds"]
            }
          },
          "response": []
        },
        {
          "name": "Get mind stats",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/minds/{{mind}}",
              "host": ["{{base_url}}"],
              "path": ["minds", "{{mind}}"]
            }
          },
          "response": []
        },
        {
          "name": "Delete a mind",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/minds/{{mind}}",
              "host": ["{{base_url}}"],
              "path": ["minds", "{{mind}}"]
            }
          },
          "response": []
        },
        {
          "name": "List wiki pages",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/minds/{{mind}}/wiki",
              "host": ["{{base_url}}"],
              "path": ["minds", "{{mind}}", "wiki"]
            }
          },
          "response": []
        },
        {
          "name": "Get a wiki page",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/minds/{{mind}}/wiki/introduction",
              "host": ["{{base_url}}"],
              "path": ["minds", "{{mind}}", "wiki", "introduction"]
            },
            "description": "Replace 'introduction' with the actual page slug."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Links",
      "item": [
        {
          "name": "Link two minds",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name_a\": \"{{mind}}\",\n  \"name_b\": \"another-mind\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/minds/link",
              "host": ["{{base_url}}"],
              "path": ["minds", "link"]
            }
          },
          "response": []
        },
        {
          "name": "Unlink two minds",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name_a\": \"{{mind}}\",\n  \"name_b\": \"another-mind\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/minds/link",
              "host": ["{{base_url}}"],
              "path": ["minds", "link"]
            }
          },
          "response": []
        },
        {
          "name": "Full link graph",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/minds/graph/all",
              "host": ["{{base_url}}"],
              "path": ["minds", "graph", "all"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Workflows",
      "item": [
        {
          "name": "Store — upload a file",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": "",
                  "description": "Select a .md, .txt, .pdf or any text file"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/minds/{{mind}}/store",
              "host": ["{{base_url}}"],
              "path": ["minds", "{{mind}}", "store"]
            }
          },
          "response": []
        },
        {
          "name": "Tap — ask a question",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"question\": \"What are the main concepts?\",\n  \"with_links\": false,\n  \"save\": false\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/minds/{{mind}}/tap",
              "host": ["{{base_url}}"],
              "path": ["minds", "{{mind}}", "tap"]
            }
          },
          "response": []
        },
        {
          "name": "Tap — stream (SSE)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"question\": \"What are the main concepts?\",\n  \"with_links\": false\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/minds/{{mind}}/tap/stream",
              "host": ["{{base_url}}"],
              "path": ["minds", "{{mind}}", "tap", "stream"]
            },
            "description": "Returns the full SSE response. For live streaming use the web UI at {{base_url}} or curl -N."
          },
          "response": []
        },
        {
          "name": "Polish — wiki health check",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/minds/{{mind}}/polish",
              "host": ["{{base_url}}"],
              "path": ["minds", "{{mind}}", "polish"]
            }
          },
          "response": []
        }
      ]
    }
  ]
}
