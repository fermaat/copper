FROM gemma3:12b

# Extended context window for wiki ingestion.
# Default is 8K — at 32K the full index + slugs + chunk content fits comfortably
# without truncation, even on large documents (300-500 pages).
# On M4 Pro 64 GB this uses ~5 GB RAM via the Neural Engine.
PARAMETER num_ctx 32768

# Cap output tokens to prevent the model from generating XML for every existing
# page on each call. 4096 tokens is enough for 3-5 well-written wiki pages.
PARAMETER num_predict 4096
