# Copper — environment configuration
# Copy to .env and fill in your values

# LLM provider: "mock" | "ollama" | (future: "anthropic" | "openai")
COPPER_LLM_PROVIDER=ollama

# Model name passed to the provider
COPPER_LLM_MODEL=gemma3:4b

# Ollama base URL — runs as an external service, not in Docker
OLLAMA_BASE_URL=http://host.docker.internal:11434

# API server
COPPER_HOST=0.0.0.0
COPPER_PORT=8000

# Copperminds storage directory inside the container (mapped via volume)
COPPER_MINDS_DIR=/data/minds
