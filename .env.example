# Copper — environment configuration
# Copy to .env and fill in your values

# ── LLM — generic fallback (used when workflow-specific values are not set) ───
# Provider: "mock" | "ollama" | "anthropic" | "openai"
COPPER_LLM_PROVIDER=ollama

# Model name passed to the provider (empty = provider default)
COPPER_LLM_MODEL=gemma3:4b

# ── LLM — store + polish (optional override) ─────────────────────────────────
# Use a more capable model for building/updating the wiki.
# Falls back to COPPER_LLM_PROVIDER / COPPER_LLM_MODEL if not set.
# COPPER_STORE_PROVIDER=anthropic
# COPPER_STORE_MODEL=claude-opus-4-6

# ── LLM — tap + chat (optional override) ─────────────────────────────────────
# Use a faster/local model for querying the wiki.
# COPPER_TAP_PROVIDER=ollama
# COPPER_TAP_MODEL=llama3.2

# ── LLM — ingest (multimodal, optional) ──────────────────────────────────────
# Used to describe images found in PDFs. Model must support vision.
# Leave empty to skip image description entirely.
# COPPER_INGEST_PROVIDER=ollama
# COPPER_INGEST_MODEL=gemma3:12b

# ── LLM — Ollama ─────────────────────────────────────────────────────────────
# Use host.docker.internal when running inside Docker; localhost otherwise
COPPER_OLLAMA_BASE_URL=http://host.docker.internal:11434
COPPER_OLLAMA_TIMEOUT=300

# ── LLM — Anthropic ──────────────────────────────────────────────────────────
# COPPER_ANTHROPIC_API_KEY=sk-ant-...
# COPPER_ANTHROPIC_TIMEOUT=300

# ── LLM — OpenAI ─────────────────────────────────────────────────────────────
# COPPER_OPENAI_API_KEY=sk-...
# COPPER_OPENAI_BASE_URL=          # empty = default OpenAI endpoint
# COPPER_OPENAI_TIMEOUT=300

# ── Storage ───────────────────────────────────────────────────────────────────
# Copperminds directory (empty = ~/.copper/minds; in Docker use /data/minds)
COPPER_MINDS_DIR=/data/minds

# ── Workflow tuning (optional) ───────────────────────────────────────────────
# Store: max chars sent to the LLM per chunk. Larger = fewer chunks but
# higher per-call token usage. Adjust to your model's context window.
# COPPER_STORE_MAX_CHUNK_CHARS=15000

# Tap: Phase 1 — max pages the LLM can pick from the wiki index per call.
# COPPER_TAP_MAX_PAGES=12
# Tap: hard ceiling on total pages sent to Phase 2 (after keyword augmentation).
# COPPER_TAP_MAX_PAGES_TOTAL=20
# Tap: default personality (prompt name). Others: tap.gamemaster, tap.scholar,
# tap.inquisitor. Register your own YAMLs in COPPER_USER_PROMPTS_DIR.
# COPPER_TAP_PERSONALITY=tap.archivist

# ── Prompts (optional) ───────────────────────────────────────────────────────
# Extra directory of YAML prompt files that override built-ins by 'name'.
# Useful to add custom personalities (e.g. project-specific gamemaster tones)
# without touching the codebase.
# COPPER_USER_PROMPTS_DIR=/path/to/my/prompts

# ── PDF ingestion tuning (optional) ──────────────────────────────────────────
# Heuristic filter applied before sending images to the multimodal model.
# Raise these to skip more decorative art; lower them to describe smaller images.
# COPPER_PDF_MIN_IMAGE_WIDTH=120
# COPPER_PDF_MIN_IMAGE_HEIGHT=120
# COPPER_PDF_MIN_IMAGE_AREA=40000

# Persist described images to <mind>/raw/images/ so the UI can render them
# alongside [Visual on page N, image M: ...] markers. Disable to save disk
# space (multimodal still runs, only the PNG files are dropped).
# COPPER_INGEST_SAVE_IMAGES=true

# ── API server ────────────────────────────────────────────────────────────────
COPPER_HOST=0.0.0.0
COPPER_PORT=8000
COPPER_RELOAD=false

# ── Logging (core-utils convention) ──────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FOLDER=logs
LOG_CONSOLE=true

# ── Environment ───────────────────────────────────────────────────────────────
ENVIRONMENT=development
