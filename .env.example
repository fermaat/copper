# Copper — environment configuration
# Copy to .env and fill in your values

# ── LLM ──────────────────────────────────────────────────────────────────────
# Provider: "mock" | "ollama" | "anthropic" | "openai"
COPPER_LLM_PROVIDER=ollama

# Model name passed to the provider
COPPER_LLM_MODEL=gemma3:4b

# Ollama base URL — runs as an external service, not in Docker
OLLAMA_BASE_URL=http://host.docker.internal:11434

# ── Storage ───────────────────────────────────────────────────────────────────
# Copperminds directory (empty = ~/.copper/minds; in Docker use /data/minds)
COPPER_MINDS_DIR=/data/minds

# ── API server ────────────────────────────────────────────────────────────────
COPPER_HOST=0.0.0.0
COPPER_PORT=8000
COPPER_RELOAD=false

# ── Logging (core-utils convention) ──────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FOLDER=logs
LOG_CONSOLE=true

# ── Environment ───────────────────────────────────────────────────────────────
ENVIRONMENT=development
